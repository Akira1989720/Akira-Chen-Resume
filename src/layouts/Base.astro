---
import site from '../data/site.json';
import '../styles-global.css';
const { seo } = site;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : '/';
const ogImage = Astro.site ? new URL(seo.ogImage, Astro.site).href : seo.ogImage;
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{seo.title}</title>
  <meta name="description" content={seo.description} />
  <meta name="author" content="陳家輝 Chia-Huei Chen" />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:site_name" content="陳家輝 Chia-Huei Chen" />
  <meta property="og:title" content="陳家輝 Chia-Huei Chen｜議題溝通與專案執行" />
  <meta property="og:description" content="橫跨出版、文化行銷與環境倡議的專案企劃。從企劃到落地，我在意細節中的價值實踐。" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="陳家輝個人網站主視覺：從企劃到落地，我在意細節中的價值實踐。" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="陳家輝 Chia-Huei Chen｜議題溝通與專案執行" />
  <meta name="twitter:description" content="橫跨出版、文化行銷與環境倡議的專案企劃。從企劃到落地，我在意細節中的價值實踐。" />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <meta name="theme-color" content="#1F4A46" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"Person","name":"陳家輝",
    "alternateName":"Chia-Huei Chen","jobTitle":"議題溝通與專案執行企劃",
    "email":"mailto:akira1989720@gmail.com","url":canonical,
    "sameAs":["https://www.linkedin.com/in/akirachen1989720"]
  })} />
</head>
<body>
  <a class="skip" href="#main">跳到主要內容</a>
  <slot />
  <script src="/main.js" is:inline></script>
</body>
</html>
